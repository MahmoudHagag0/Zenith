generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User identity model — S1-002 (see Sprint Brief Scope item 1).
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  watchlists      Watchlist[]
  favouriteAssets FavouriteAsset[]
  portfolios      Portfolio[]
  journalEntries  JournalEntry[]
  alerts          Alert[]
}

enum Role {
  USER
  ADMIN
}

// Trading Catalog — S1-003 (see Sprint Brief Scope item 1). Shared reference data.
model Exchange {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  markets Market[]
}

enum MarketType {
  EQUITY
  CRYPTO
  FOREX
  COMMODITY
}

model Market {
  id         String     @id @default(uuid())
  exchangeId String
  name       String
  type       MarketType
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  exchange Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  assets   Asset[]

  @@unique([exchangeId, name])
}

model Asset {
  id        String   @id @default(uuid())
  marketId  String
  symbol    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  market           Market            @relation(fields: [marketId], references: [id], onDelete: Cascade)
  watchlistItems   WatchlistItem[]
  favouritedBy     FavouriteAsset[]
  positions        Position[]
  quote            MarketQuote?
  candles          Candle[]
  alerts           Alert[]
  newsItems        NewsItem[]
  calendarEvents   CalendarEvent[]
  cotReports       CotReport[]
  corporateActions CorporateAction[]

  @@unique([marketId, symbol])
}

// User Watchlist foundation — S1-003 (see Sprint Brief Scope item 1). Strictly user-owned.
model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@unique([userId, name])
}

model WatchlistItem {
  id          String   @id @default(uuid())
  watchlistId String
  assetId     String
  addedAt     DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, assetId])
}

model FavouriteAsset {
  id        String   @id @default(uuid())
  userId    String
  assetId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

// Portfolio & Position accounting foundation — S1-004 (see Sprint Brief Scope item 1).
// Strictly user-owned. Position quantity/averageCost/realizedPnl are derived exclusively
// from recorded Transactions (see DEC-2026-005) — never set directly by a client.
model Portfolio {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions Position[]

  @@unique([userId, name])
}

model Position {
  id          String   @id @default(uuid())
  portfolioId String
  assetId     String
  quantity    Decimal  @default(0) @db.Decimal(24, 8)
  averageCost Decimal  @default(0) @db.Decimal(24, 8)
  realizedPnl Decimal  @default(0) @db.Decimal(24, 8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  // Restrict (not Cascade): an Asset with open positions must not be silently
  // deletable, since that would destroy a trader's financial history.
  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@unique([portfolioId, assetId])
}

enum TransactionType {
  BUY
  SELL
}

model Transaction {
  id         String          @id @default(uuid())
  positionId String
  type       TransactionType
  quantity   Decimal         @db.Decimal(24, 8)
  price      Decimal         @db.Decimal(24, 8)
  executedAt DateTime        @default(now())
  createdAt  DateTime        @default(now())

  position       Position       @relation(fields: [positionId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
}

// Trading Journal — S1-029 (Phase 1 of the post-S1-024 roadmap). Strictly
// user-owned, mirroring Watchlist/Portfolio. Optionally linked to a specific
// Transaction for traceability, never required (a reflection can stand alone).
model JournalEntry {
  id            String   @id @default(uuid())
  userId        String
  transactionId String?
  title         String
  content       String
  tags          String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SetNull (not Cascade): deleting the underlying Transaction must not
  // destroy the trader's own written reflection -- it just becomes unlinked.
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId])
}

enum AlertConditionType {
  DIRECTION_BULLISH
  DIRECTION_BEARISH
  PRICE_ABOVE
  PRICE_BELOW
}

enum AlertStatus {
  ACTIVE
  TRIGGERED
}

// Alerts — S1-030 (Phase 2 of the post-S1-024 roadmap). Strictly user-owned,
// mirroring Watchlist/JournalEntry. Direction conditions are evaluated
// against the existing Confluence Engine reading (InstrumentReadingService);
// price conditions against the existing cached MarketQuote (MarketDataService)
// -- no new signal source is introduced.
model Alert {
  id            String             @id @default(uuid())
  userId        String
  assetId       String
  conditionType AlertConditionType
  targetPrice   Decimal?           @db.Decimal(24, 8)
  status        AlertStatus        @default(ACTIVE)
  triggeredAt   DateTime?
  triggeredNote String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// Market Data Foundation — S1-005 (see Sprint Brief Scope items 3-4). Shared cache,
// not user-owned. All data is sourced via the MarketDataProvider interface (ADR-003);
// as of S1-005 the only registered provider is simulated, not real market data.
model MarketQuote {
  id        String   @id @default(uuid())
  assetId   String   @unique
  price     Decimal  @db.Decimal(24, 8)
  currency  String   @default("USD")
  provider  String
  asOf      DateTime
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// Calendar / News — S1-031 (Phase 3 of the post-S1-024 roadmap). Shared cache,
// not user-owned (mirrors MarketQuote/Candle) -- sourced via a new
// CalendarNewsProvider abstraction (mirroring ADR-003's MarketDataProvider),
// the first new external-data ingestion domain since S1-005.
enum NewsCategory {
  EARNINGS
  ECONOMIC
  MARKET
  COMPANY
}

enum CalendarImportance {
  LOW
  MEDIUM
  HIGH
}

model NewsItem {
  id          String       @id @default(uuid())
  assetId     String?
  headline    String
  summary     String
  category    NewsCategory
  source      String
  publishedAt DateTime
  createdAt   DateTime     @default(now())

  asset Asset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Foundation Hardening (Acceptance Review, Medium #1): a real natural key,
  // replacing the findFirst-then-create idempotent guard the service used to
  // rely on -- that guard was not safe under concurrent requests populating
  // the same uncached asset. Caching now upserts against this constraint.
  @@unique([assetId, headline, publishedAt])
  @@index([assetId])
  @@index([publishedAt])
}

model CalendarEvent {
  id          String             @id @default(uuid())
  assetId     String?
  title       String
  category    NewsCategory
  importance  CalendarImportance
  description String
  scheduledAt DateTime
  createdAt   DateTime           @default(now())

  asset Asset? @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Same rationale as NewsItem's own unique constraint above.
  @@unique([assetId, title, scheduledAt])
  @@index([assetId])
  @@index([scheduledAt])
}

// COT (Commitment of Traders) — S1-032 (Phase 4 of the post-S1-024 roadmap).
// Shared cache, not user-owned (mirrors MarketQuote/NewsItem) -- sourced via
// a new CotProvider abstraction (mirroring ADR-003), directly reusing the
// ingestion pattern Phase 3 (Calendar/News) established.
enum CotTraderCategory {
  COMMERCIAL
  NON_COMMERCIAL
  NON_REPORTABLE
}

model CotReport {
  id             String            @id @default(uuid())
  assetId        String
  reportDate     DateTime
  category       CotTraderCategory
  longPositions  Int
  shortPositions Int
  netPosition    Int
  provider       String
  createdAt      DateTime          @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, reportDate, category])
  @@index([assetId])
}

// Corporate Actions (splits & dividends) — L1-006 (28_LIVE_DATA_BLUEPRINT.md
// §9 Phase 6). Architecture Team decision (2026-07-16): stored fully
// independently from Candle/Position/Transaction -- this table is never
// joined into, and never mutates, any existing financial data. Any future
// adjustment consumer must compute on read from this table; this Sprint
// only ingests and stores the raw events. `rawPayload` preserves the
// provider's original response for full audit/reproducibility, per the
// same Architecture Team decision's traceability requirement.
enum CorporateActionType {
  SPLIT
  DIVIDEND
}

model CorporateAction {
  id              String              @id @default(uuid())
  assetId         String
  type            CorporateActionType
  effectiveDate   DateTime
  ratio           Decimal?            @db.Decimal(24, 8) // SPLIT only: toFactor / fromFactor (e.g. 2.0 for a 2-for-1 split, 0.5 for a 1-for-2 reverse split)
  amount          Decimal?            @db.Decimal(24, 8) // DIVIDEND only: cash amount per share
  currency        String? // DIVIDEND only
  provider        String
  providerEventId String?
  retrievedAt     DateTime            @default(now())
  rawPayload      Json
  createdAt       DateTime            @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // Idempotency natural key (Architecture Team requirement: reprocessing the
  // same split/dividend must never create duplicates) -- mirrors the exact
  // upsert-against-a-real-natural-key convention already used by
  // NewsItem/CalendarEvent/CotReport.
  @@unique([assetId, type, effectiveDate])
  @@index([assetId])
}

model Candle {
  id        String   @id @default(uuid())
  assetId   String
  date      DateTime
  open      Decimal  @db.Decimal(24, 8)
  high      Decimal  @db.Decimal(24, 8)
  low       Decimal  @db.Decimal(24, 8)
  close     Decimal  @db.Decimal(24, 8)
  volume    Decimal  @db.Decimal(24, 8)
  provider  String
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, date])
}
