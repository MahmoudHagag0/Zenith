generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User identity model — S1-002 (see Sprint Brief Scope item 1).
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  watchlists       Watchlist[]
  favouriteAssets  FavouriteAsset[]
  portfolios       Portfolio[]
}

enum Role {
  USER
  ADMIN
}

// Trading Catalog — S1-003 (see Sprint Brief Scope item 1). Shared reference data.
model Exchange {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  markets Market[]
}

enum MarketType {
  EQUITY
  CRYPTO
  FOREX
  COMMODITY
}

model Market {
  id         String     @id @default(uuid())
  exchangeId String
  name       String
  type       MarketType
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  exchange Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  assets   Asset[]

  @@unique([exchangeId, name])
}

model Asset {
  id        String   @id @default(uuid())
  marketId  String
  symbol    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  market          Market           @relation(fields: [marketId], references: [id], onDelete: Cascade)
  watchlistItems  WatchlistItem[]
  favouritedBy    FavouriteAsset[]
  positions       Position[]

  @@unique([marketId, symbol])
}

// User Watchlist foundation — S1-003 (see Sprint Brief Scope item 1). Strictly user-owned.
model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WatchlistItem[]

  @@unique([userId, name])
}

model WatchlistItem {
  id          String   @id @default(uuid())
  watchlistId String
  assetId     String
  addedAt     DateTime @default(now())

  watchlist Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, assetId])
}

model FavouriteAsset {
  id        String   @id @default(uuid())
  userId    String
  assetId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

// Portfolio & Position accounting foundation — S1-004 (see Sprint Brief Scope item 1).
// Strictly user-owned. Position quantity/averageCost/realizedPnl are derived exclusively
// from recorded Transactions (see DEC-2026-005) — never set directly by a client.
model Portfolio {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  positions Position[]

  @@unique([userId, name])
}

model Position {
  id          String   @id @default(uuid())
  portfolioId String
  assetId     String
  quantity    Decimal  @default(0) @db.Decimal(24, 8)
  averageCost Decimal  @default(0) @db.Decimal(24, 8)
  realizedPnl Decimal  @default(0) @db.Decimal(24, 8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio    Portfolio     @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  // Restrict (not Cascade): an Asset with open positions must not be silently
  // deletable, since that would destroy a trader's financial history.
  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@unique([portfolioId, assetId])
}

enum TransactionType {
  BUY
  SELL
}

model Transaction {
  id         String          @id @default(uuid())
  positionId String
  type       TransactionType
  quantity   Decimal         @db.Decimal(24, 8)
  price      Decimal         @db.Decimal(24, 8)
  executedAt DateTime        @default(now())
  createdAt  DateTime        @default(now())

  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
}
