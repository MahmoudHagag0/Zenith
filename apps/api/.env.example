DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zenith?schema=public
JWT_SECRET=change-me-in-local-env
JWT_EXPIRATION=1h
PORT=3000
LOG_LEVEL=info

# Live Data (L1-001, 28_LIVE_DATA_BLUEPRINT.md). Unset or MARKET_DATA_MODE
# not "live" falls back to SimulatedMarketDataProvider automatically.
MARKET_DATA_MODE=simulated
TWELVE_DATA_API_KEY=

# Live Data (L1-003, 28_LIVE_DATA_BLUEPRINT.md §9 Phase 3). Unset or
# CALENDAR_NEWS_MODE not "live" (or any of the three keys missing) falls
# back to SimulatedCalendarNewsProvider automatically.
CALENDAR_NEWS_MODE=simulated
FMP_API_KEY=
FINNHUB_API_KEY=
MARKETAUX_API_KEY=

# Live Data (L1-004, 28_LIVE_DATA_BLUEPRINT.md §9 Phase 4). Unset or
# COT_MODE not "live" falls back to SimulatedCotProvider automatically.
# No API key is required -- CFTC's public reporting data is free and
# open; CFTC_APP_TOKEN is Socrata's optional higher-rate-limit token.
COT_MODE=simulated
CFTC_APP_TOKEN=

# Live Data (L1-006, 28_LIVE_DATA_BLUEPRINT.md §9 Phase 6). Unset or
# CORPORATE_ACTIONS_MODE not "live" falls back to
# SimulatedCorporateActionsProvider automatically. Reuses FINNHUB_API_KEY
# above -- no separate credential is introduced for this domain.
CORPORATE_ACTIONS_MODE=simulated
